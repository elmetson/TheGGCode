# The GG Code - Environment Variables Template
# Copy this file to .env and fill in your actual API keys

# Brave Search API Configuration
REACT_APP_BRAVE_API_KEY=your_brave_api_key_here

# OpenRouter API Configuration (for Llama-3.3-70B-Instruct:free)
REACT_APP_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Supabase Database Configuration
REACT_APP_SUPABASE_URL=your_supabase_project_url_here
REACT_APP_SUPABASE_KEY=your_supabase_anon_key_here

# Instructions:
# 1. Get Brave Search API key from: https://api.search.brave.com/
# 2. Get OpenRouter API key from: https://openrouter.ai/
# 3. Create Supabase project at: https://supabase.com/
# 4. Copy this file to .env and replace the placeholder values
# 5. Restart your development server after adding keys